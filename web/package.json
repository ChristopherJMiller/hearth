{
  "private": true,
  "scripts": {
    "dev": "concurrently -n catalog,console -c blue,magenta \"pnpm --filter @hearth/catalog dev\" \"pnpm --filter @hearth/console dev\"",
    "dev:catalog": "pnpm --filter @hearth/catalog dev",
    "dev:console": "pnpm --filter @hearth/console dev",
    "build": "pnpm --filter @hearth/ui build && pnpm --filter @hearth/catalog build && pnpm --filter @hearth/console build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.0",
    "react-icons": "^4.12.0",
    "tailwindcss": "^4.2.0"
  },
  "devDependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-table": "^8.21.3",
    "concurrently": "^9.2.1"
  }
}
